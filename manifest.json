{
  "manifest_version": 3,
  "name": "LeetCode Hinter",
  "version": "1.0.0",
  "description": "Get contextual hints while solving LeetCode problems.",
  "permissions": [
    "storage",
    "sidePanel",
    "declarativeNetRequest"
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_title": "Toggle LeetCode Hinter",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.leetcode.com/*",
        "*://*.leetcode.cn/*"
      ],
      "js": ["src/content.ts"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "host_permissions": [
    "*://*.leetcode.com/*",
    "*://*.leetcode.cn/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.deepseek.com/*",
    "https://openrouter.ai/*",
    "https://api.together.xyz/*",
    "http://localhost:11434/*",
    "https://ollama.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["overlay.html"],
      "matches": ["*://*.leetcode.com/*", "*://*.leetcode.cn/*"]
    }
  ]
}
